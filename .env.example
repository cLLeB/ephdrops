# ─── Required ────────────────────────────────────────────────
# HMAC secret used to sign .eph drop packets. Generate a strong random value:
#   openssl rand -hex 32
EPH_SECRET=replace-me-with-a-32-byte-random-hex-string

# ─── Optional ────────────────────────────────────────────────
# Port the server listens on (must match the client dev proxy in vite.config.js).
PORT=3002

# Public base URL embedded in generated .eph packets and drop links.
# In production set this to the URL where this app is deployed.
APP_URL=http://localhost:3002

# ─── Cloudflare R2 (optional) ────────────────────────────────
# When ALL FOUR of these are set, encrypted blobs are stored in R2 and the
# browser uploads/downloads them directly via short-lived presigned URLs — the
# server never holds the payload, so large uploads (up to 100MB) work and the
# server stays lightweight. Leave them unset to store ciphertext in server
# memory instead (fine for local dev; capped at 25MB).
#
# Create the access key/secret in: Cloudflare → R2 → Manage R2 API Tokens →
# create a token with "Object Read & Write" scoped to your bucket.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key-id
# R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET=your-bucket-name

# Presigned URL lifetimes in seconds (optional — sane defaults shown).
# R2_PUT_EXPIRY_SECONDS=600
# R2_GET_EXPIRY_SECONDS=300
