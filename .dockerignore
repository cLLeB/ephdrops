# Dependencies — reinstalled inside the image from lockfiles
node_modules/
**/node_modules/

# Build outputs — the client is rebuilt inside the image
dist/
**/dist/
build/
out/
.cache/

# Secrets — never bake these into the image; supply via Space Secrets
.env
.env.local
.env.*.local

# Version control & tooling
.git/
.gitignore
.github/

# Logs
npm-debug.log*
yarn-debug.log*
*.log

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
